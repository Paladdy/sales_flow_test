# =============================================================================
# Sales Flow — local infrastructure
# Copy: cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=salesflow
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=sales_flow
POSTGRES_PORT=5432

# --- n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
# Public URL for Telegram webhooks (use ngrok/cloudflare tunnel in dev)
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Europe/Moscow

# Basic auth for n8n UI (recommended even locally)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n
N8N_ENCRYPTION_KEY=local-dev-key-change-in-prod-32chars

# --- External API keys (used in n8n Credentials, listed here for reference) ---
# OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
N8N_TG_WEBHOOK_ID=
N8N_TG_WEBHOOK_SECRET=
# UPSTREAM_WEBHOOK_SECRET=

# --- Pilot seed (update after Telegram bot setup) ---
SEED_EMPLOYEE_TELEGRAM_CHAT_ID=000000000
SEED_REGIONAL_TELEGRAM_CHAT_ID=000000000
SEED_OPS_TELEGRAM_CHAT_ID=000000000

# --- Metabase (optional profile: dashboard) ---
METABASE_PORT=3000

# --- Ollama (local LLM for WF-02, no API keys) ---
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:1b

          "name": "Sales Flow Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE pending_training_actions\nSET used_at = NOW()\nWHERE action_token = '{{ $('Parse Callback').first().json.action_token }}'::uuid;\n\nUPDATE dialogs\nSET status = 'training_skipped', updated_at = NOW()\nWHERE dialog_id = '{{ $json.dialog_id }}'::uuid\nRETURNING dialog_id, status;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",

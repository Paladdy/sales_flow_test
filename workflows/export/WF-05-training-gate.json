    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.action_token, p.dialog_id, d.employee_id, d.status\nFROM pending_training_actions p\nJOIN dialogs d ON d.dialog_id = p.dialog_id\nWHERE p.action_token = '{{ $json.action_token }}'::uuid\n  AND p.used_at IS NULL\n  AND p.expires_at > NOW()\n  AND d.status = 'awaiting_training_confirm';",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",

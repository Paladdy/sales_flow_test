          "id": "__POSTGRES_CRED_ID__",
          "name": "Sales Flow Postgres"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "{\n  \"status\": \"notified\",\n  \"dialog_id\": \"={{ $('Build Employee Message').item.json.dialog_id }}\"\n}",
        "options": {}
      },
